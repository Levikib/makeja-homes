#!/bin/sh
# Pre-commit: TypeScript type check
# Blocks the commit if tsc finds errors in project files (ignores node_modules)

echo "🔍 Running TypeScript check..."

cd "$(git rev-parse --show-toplevel)"

# If .next/types hasn't been generated yet (no build run), skip those errors.
# They're Next.js-generated stale-type references — not real code errors.
TS_ERRORS=$(npx tsc --noEmit 2>&1 \
  | grep "error TS" \
  | grep -v "node_modules" \
  | grep -v "\.next/types")

if [ -n "$TS_ERRORS" ]; then
  echo ""
  echo "❌ TypeScript errors found — commit blocked:"
  echo ""
  echo "$TS_ERRORS"
  echo ""
  echo "Fix the errors above, then try committing again."
  exit 1
fi

echo "✅ TypeScript check passed."
exit 0
